<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>GR8 Software Solutions</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#03152f;
    color:white;
    overflow-x:hidden;
}

/* BACKGROUND */

body::before{
    content:"";
    position:fixed;
    inset:0;
    background:
    radial-gradient(circle at top left,#005eff 0%,transparent 25%),
    radial-gradient(circle at bottom right,#00aaff 0%,transparent 25%),
    linear-gradient(145deg,#03152f,#062b63,#041933);
    z-index:-5;
}

/* GLOW EFFECT */

.glow{
    position:fixed;
    width:350px;
    height:350px;
    border-radius:50%;
    filter:blur(130px);
    opacity:.35;
    z-index:-2;
}

.glow1{
    background:#0066ff;
    top:-100px;
    left:-100px;
}

.glow2{
    background:#00aeff;
    bottom:-100px;
    right:-100px;
}

/* APP */

.app{
    max-width:1280px;
    margin:auto;
    padding:25px;
}

/* NAVBAR */

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:10px 0 30px;
}

.logo{
    font-size:44px;
    font-weight:900;
    color:white;
    letter-spacing:2px;
}

.logo span{
    color:#00aeff;
}

.nav-links{
    display:flex;
    gap:30px;
}

.nav-links a{
    text-decoration:none;
    color:white;
    font-weight:700;
    transition:.3s;
    position:relative;
}

.nav-links a:hover{
    color:#00aeff;
}

/* HERO */

.hero{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:60px;
    align-items:center;
    min-height:90vh;
}

.hero-text h1{
    font-size:88px;
    line-height:1;
    font-weight:900;
    text-transform:uppercase;

    background:linear-gradient(90deg,#ffffff,#65b8ff,#00aaff);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.hero-text p{
    margin-top:28px;
    color:#d8e7ff;
    line-height:1.9;
    font-size:18px;
}

/* BUTTONS */

.hero-buttons{
    margin-top:35px;
    display:flex;
    flex-wrap:wrap;
    gap:18px;
}

.btn{
    position:relative;
    overflow:hidden;
    padding:18px 30px;
    border:none;
    border-radius:20px;
    text-decoration:none;
    font-weight:800;
    font-size:16px;
    cursor:pointer;
    transition:.35s;
}

.btn:hover{
    transform:translateY(-5px) scale(1.03);
}

/* SHINE EFFECT */

.btn::before{
    content:"";
    position:absolute;
    top:0;
    left:-120%;
    width:60%;
    height:100%;
    background:linear-gradient(
        90deg,
        transparent,
        rgba(255,255,255,.5),
        transparent
    );
    transform:skewX(-25deg);
    animation:shine 4s infinite;
}

@keyframes shine{
    100%{
        left:160%;
    }
}

/* PRIMARY */

.primary{
    background:linear-gradient(135deg,#0066ff,#00b7ff);
    color:white;

    box-shadow:
    0 10px 30px rgba(0,102,255,.45),
    0 10px 40px rgba(0,183,255,.35);
}

.primary:hover{
    box-shadow:
    0 0 30px rgba(0,183,255,.9),
    0 0 60px rgba(0,102,255,.7);
}

/* SECONDARY */

.secondary{
    background:rgba(255,255,255,.08);
    color:white;
    border:1px solid rgba(255,255,255,.15);
    backdrop-filter:blur(12px);
}

/* HERO IMAGE */

.hero-card{
    position:relative;
    border-radius:35px;
    overflow:hidden;
    height:560px;
    box-shadow:0 25px 60px rgba(0,0,0,.45);
}

.hero-card img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.hero-overlay{
    position:absolute;
    inset:0;
    background:linear-gradient(to top,rgba(0,0,0,.85),transparent);
    display:flex;
    align-items:flex-end;
    padding:35px;
}

.hero-overlay h2{
    font-size:42px;
    margin-bottom:12px;
}

.hero-overlay p{
    color:#ddd;
    line-height:1.7;
}

/* SECTION */

.section{
    margin-top:120px;
}

.section-title{
    text-align:center;
    font-size:70px;
    font-weight:900;
    margin-bottom:18px;

    background:linear-gradient(90deg,#ffffff,#65b8ff,#00aeff);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.section-subtitle{
    text-align:center;
    max-width:850px;
    margin:auto;
    line-height:1.9;
    color:#d6e5ff;
    font-size:18px;
}

/* CARDS */

.cards{
    margin-top:60px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:28px;
}

.card{
    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.12);
    backdrop-filter:blur(18px);

    padding:35px;
    border-radius:30px;

    transition:.35s;

    box-shadow:0 15px 35px rgba(0,0,0,.25);
}

.card:hover{
    transform:translateY(-10px) scale(1.02);

    box-shadow:
    0 15px 40px rgba(0,102,255,.35),
    0 15px 50px rgba(0,183,255,.25);
}

.card h3{
    font-size:30px;
    margin-bottom:18px;
    color:#7fc5ff;
}

.card p{
    color:#d7e6ff;
    line-height:1.9;
}

/* PRODUCTS */

.products{
    margin-top:60px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:28px;
}

.product-box{
    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.12);
    backdrop-filter:blur(16px);

    padding:35px;
    border-radius:30px;

    transition:.35s;
}

.product-box:hover{
    transform:translateY(-10px);
}

.product-box h3{
    font-size:32px;
    color:#79c2ff;
    margin-bottom:20px;
}

.product-box ul{
    padding-left:20px;
    line-height:2;
    color:#dce9ff;
}

/* TEAM */

.team{
    margin-top:60px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:30px;
}

.team-member{
    background:rgba(255,255,255,.08);
    border-radius:35px;
    overflow:hidden;
    border:1px solid rgba(255,255,255,.1);

    backdrop-filter:blur(12px);

    transition:.35s;
}

.team-member:hover{
    transform:translateY(-10px) scale(1.02);
}

.team-member img{
    width:100%;
    height:420px;
    object-fit:cover;
}

.team-content{
    padding:28px;
    text-align:center;
}

.team-content h3{
    font-size:28px;
    margin-bottom:8px;
}

.team-content p{
    color:#bcd6ff;
}

/* CONTACT */

.contact-box{
    margin-top:60px;
    border-radius:40px;
    padding:70px 40px;

    background:linear-gradient(135deg,#005eff,#00aeff);

    text-align:center;

    box-shadow:
    0 20px 50px rgba(0,94,255,.4),
    0 20px 60px rgba(0,174,255,.25);
}

.contact-box h2{
    font-size:60px;
    margin-bottom:18px;
}

.contact-box p{
    font-size:19px;
    line-height:1.9;
    max-width:800px;
    margin:auto;
}

.contact-buttons{
    margin-top:35px;
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.contact-btn{
    padding:18px 28px;
    border-radius:18px;
    text-decoration:none;
    font-weight:800;
    background:white;
    color:#005eff;
    transition:.3s;
}

.contact-btn:hover{
    transform:translateY(-5px) scale(1.03);
}

/* FOOTER */

.footer{
    margin-top:80px;
    text-align:center;
    color:#b7cfff;
    padding-bottom:30px;
}

/* MOBILE */

@media(max-width:980px){

    .hero{
        grid-template-columns:1fr;
    }

    .hero-text h1{
        font-size:58px;
    }

    .section-title{
        font-size:48px;
    }

    .navbar{
        flex-direction:column;
        gap:20px;
    }

}

@media(max-width:600px){

    .hero-text h1{
        font-size:42px;
    }

    .section-title{
        font-size:38px;
    }

    .hero-card{
        height:420px;
    }

}

</style>
</head>

<body>

<div class="glow glow1"></div>
<div class="glow glow2"></div>

<div class="app">

    <!-- NAVBAR -->

    <div class="navbar">

        <div class="logo">
            GR8<span>SOFT</span>
        </div>

        <div class="nav-links">
            <a href="#about">About</a>
            <a href="#services">Services</a>
            <a href="#products">Products</a>
            <a href="#team">Team</a>
            <a href="#contact">Contact</a>
        </div>

    </div>

    <!-- HERO -->

    <section class="hero" id="about">

        <div class="hero-text">

            <h1>
                GR8 SOFTWARE SOLUTIONS
            </h1>

            <p>
                Integr8 Software Solutions, Inc. delivers
                powerful ERP systems, accounting software,
                HRIS, POS systems, and cloud solutions
                designed to help businesses grow faster,
                smarter, and more efficiently across the Philippines.
            </p>

            <div class="hero-buttons">

                <a href="#products" class="btn primary">
                    Explore Products
                </a>

                <a href="#contact" class="btn secondary">
                    Contact Us
                </a>

            </div>

        </div>

        <div class="hero-card">

            <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=1200&auto=format&fit=crop">

            <div class="hero-overlay">

                <div>

                    <h2>Modern ERP Solutions</h2>

                    <p>
                        Reliable systems built for businesses,
                        cooperatives, retail, lending, and enterprises.
                    </p>

                </div>

            </div>

        </div>

    </section>

    <!-- SERVICES -->

    <section class="section" id="services">

        <h2 class="section-title">
            OUR SERVICES
        </h2>

        <p class="section-subtitle">
            We create modern software systems that improve
            business operations, automate processes,
            and increase productivity.
        </p>

        <div class="cards">

            <div class="card">

                <h3>ERP Solutions</h3>

                <p>
                    Complete enterprise resource planning systems
                    for accounting, inventory, billing,
                    payroll, and management operations.
                </p>

            </div>

            <div class="card">

                <h3>Cloud Systems</h3>

                <p>
                    Secure cloud-based and on-premise software
                    solutions with scalable infrastructure
                    and reliable performance.
                </p>

            </div>

            <div class="card">

                <h3>Custom Development</h3>

                <p>
                    Tailor-made software solutions built specifically
                    for your business processes and workflow requirements.
                </p>

            </div>

        </div>

    </section>

    <!-- PRODUCTS -->

    <section class="section" id="products">

        <h2 class="section-title">
            OUR PRODUCTS
        </h2>

        <p class="section-subtitle">
            Powerful business software solutions trusted
            by companies and organizations nationwide.
        </p>

        <div class="products">

            <div class="product-box">

                <h3>GR8Books</h3>

                <ul>
                    <li>Accounting Software</li>
                    <li>Inventory Management</li>
                    <li>Financial Reports</li>
                    <li>Billing & Monitoring</li>
                </ul>

            </div>

            <div class="product-box">

                <h3>Payroll & HRIS</h3>

                <ul>
                    <li>Payroll Processing</li>
                    <li>Attendance Monitoring</li>
                    <li>Employee Records</li>
                    <li>Government Compliance</li>
                </ul>

            </div>

            <div class="product-box">

                <h3>POS System</h3>

                <ul>
                    <li>Retail & Grocery POS</li>
                    <li>Inventory Tracking</li>
                    <li>Sales Reports</li>
                    <li>Customer Monitoring</li>
                </ul>

            </div>

        </div>

    </section>

    <!-- TEAM -->

    <section class="section" id="team">

        <h2 class="section-title">
            OUR TEAM
        </h2>

        <p class="section-subtitle">
            A strong team driven by innovation,
            collaboration, and commitment to excellence.
        </p>

        <div class="team">

            <div class="team-member">

                <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200&auto=format&fit=crop">

                <div class="team-content">

                    <h3>Paul Andrew Santamaria</h3>

                    <p>President</p>

                </div>

            </div>

            <div class="team-member">

                <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=1200&auto=format&fit=crop">

                <div class="team-content">

                    <h3>Anjomarc Topacio</h3>

                    <p>IT Director</p>

                </div>

            </div>

            <div class="team-member">

                <img src="https://images.unsplash.com/photo-1504257432389-52343af06ae3?q=80&w=1200&auto=format&fit=crop">

                <div class="team-content">

                    <h3>Mikko Crizaldo</h3>

                    <p>IT Director</p>

                </div>

            </div>

        </div>

    </section>

    <!-- CONTACT -->

    <section class="section" id="contact">

        <div class="contact-box">

            <h2>
                CONTACT US
            </h2>

            <p>
                Ready to transform your business
                with modern software solutions?
                Let’s build something powerful together.
            </p>

            <div class="contact-buttons">

                <a href="tel:+639171197231" class="contact-btn">
                    📞 0917-119-7231
                </a>

                <a href="https://www.integr8.com.ph" class="contact-btn">
                    🌐 Visit Website
                </a>

                <a href="mailto:info@integr8.com.ph" class="contact-btn">
                    ✉ Email Us
                </a>

            </div>

        </div>

    </section>

    <!-- FOOTER -->

    <div class="footer">
        © 2026 GR8 Software Solutions • Innovative ERP & Software Systems
    </div>

</div>

</body>
</html>
